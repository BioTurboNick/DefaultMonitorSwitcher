<Application x:Class="DefaultMonitorSwitcher.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:tb="http://www.hardcodet.net/taskbar">
    <Application.Resources>

        <tb:TaskbarIcon x:Key="TrayIcon"
                        ToolTipText="DefaultMonitorSwitcher"
                        Visibility="Collapsed">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="{Binding StatusText}"
                              IsEnabled="False" FontWeight="SemiBold"/>
                    <Separator/>
                    <MenuItem Header="Revert to Desktop"
                              Command="{Binding RevertNowCommand}"
                              IsEnabled="{Binding IsHdtvPrimary}"/>
                    <MenuItem Header="TV Show Mode"
                              IsCheckable="True"
                              IsChecked="{Binding TvShowModeEnabled}"/>
                    <Separator/>
                    <MenuItem Header="Settings…"
                              Command="{Binding OpenSettingsCommand}"/>
                    <Separator/>
                    <MenuItem Header="Exit"
                              Command="{Binding ExitCommand}"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>

    </Application.Resources>
</Application>
